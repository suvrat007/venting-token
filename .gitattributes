# Normalize all text files to LF on commit
* text=auto eol=lf

# Solidity source files
*.sol text eol=lf

# Web / config
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binaries — never convert
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff2 binary
